{
  "name": "egghead-beginners-guide-to-react",
  "version": "1.0.0",
  "description": "A fuller implementation of egghead.io Beginners Guide To React by Kent C Dodds with modules, unit testing, etc",
  "repository": {
    "type": "git",
    "url": "git@github.com-speakingcode:speakingcode/egghead-beginners-guide-to-react.git"
  },
  "license": "ISC",
  "author": "speakingcode",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "webpack-dev-server --content-base src",
    "test": "jest",
    "test:watch": "npm run test -- --watchAll",
    "build": "NODE_ENV=production webpack && cp src/index.html dist/index.html"
  },
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-react"
    ],
    "plugins": [
      "@babel/plugin-transform-object-rest-spread"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-object-rest-spread": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "babel-loader": "^10.1.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react-test-renderer": "^19.2.4",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
